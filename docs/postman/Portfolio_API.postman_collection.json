{
  "info": {
    "_postman_id": "portfolio-api-collection",
    "name": "Portfolio API",
    "description": "REST API for the personal portfolio backend. Base URL: {{baseUrl}}/api/v1\n\nAuthentication: JWT Bearer token. Login via POST /auth/login to get a token, then set it as {{authToken}} in the environment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [],
  "item": [
    {
      "name": "Auth",
      "description": "Authentication endpoints",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.environment.set('authToken', res.data.token);",
                  "  console.log('Token saved:', res.data.token.substring(0, 20) + '...');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Login and receive a JWT token. The test script auto-saves the token to {{authToken}}."
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "me"]
            },
            "description": "Get the currently authenticated user's profile."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "logout"]
            }
          }
        },
        {
          "name": "Register User (Admin only)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Admin\",\n  \"email\": \"newadmin@example.com\",\n  \"password\": \"securepassword123\",\n  \"role\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "Register a new user. Requires admin JWT token."
          }
        }
      ]
    },
    {
      "name": "Projects",
      "description": "Project CRUD endpoints. GET routes are public; POST/PUT/DELETE require JWT.",
      "item": [
        {
          "name": "Get All Projects",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/projects?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "projects"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "category", "value": "web", "disabled": true },
                { "key": "featured", "value": "true", "disabled": true },
                { "key": "status", "value": "completed", "disabled": true }
              ]
            },
            "description": "Get paginated list of projects. Optional filters: category (web|mobile|fullstack|other), featured (bool), status (planning|in-progress|completed|archived)."
          }
        },
        {
          "name": "Get Project by Slug",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/projects/:slug",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "projects", ":slug"],
              "variable": [{ "key": "slug", "value": "my-project-slug" }]
            }
          }
        },
        {
          "name": "Create Project",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "My New Project", "type": "text" },
                { "key": "description", "value": "Short description (max 500 chars)", "type": "text" },
                { "key": "fullDescription", "value": "Full markdown description of the project", "type": "text" },
                { "key": "category", "value": "web", "type": "text" },
                { "key": "technologies", "value": "[\"React\",\"Node.js\",\"MongoDB\"]", "type": "text", "description": "JSON array" },
                { "key": "featured", "value": "false", "type": "text" },
                { "key": "status", "value": "in-progress", "type": "text" },
                { "key": "links", "value": "{\"github\":\"https://github.com/user/repo\",\"live\":\"https://example.com\"}", "type": "text", "description": "JSON object" },
                { "key": "highlights", "value": "[\"Achievement 1\",\"Achievement 2\"]", "type": "text", "description": "JSON array" },
                { "key": "challenges", "value": "[\"Challenge 1\"]", "type": "text", "description": "JSON array" },
                { "key": "learnings", "value": "[\"Learning 1\"]", "type": "text", "description": "JSON array" },
                { "key": "order", "value": "1", "type": "text" },
                { "key": "images", "value": "", "type": "file", "disabled": true, "description": "Up to 5 image files" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/projects",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "projects"]
            },
            "description": "Create a new project. Accepts multipart/form-data with optional image uploads."
          }
        },
        {
          "name": "Update Project",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Updated Project Title", "type": "text" },
                { "key": "description", "value": "Updated description", "type": "text" },
                { "key": "featured", "value": "true", "type": "text" },
                { "key": "status", "value": "completed", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/projects/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "projects", ":id"],
              "variable": [{ "key": "id", "value": "{{projectId}}" }]
            }
          }
        },
        {
          "name": "Delete Project",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/projects/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "projects", ":id"],
              "variable": [{ "key": "id", "value": "{{projectId}}" }]
            }
          }
        }
      ]
    },
    {
      "name": "Skills",
      "description": "Skill CRUD endpoints. GET routes are public; POST/PUT/DELETE require JWT.",
      "item": [
        {
          "name": "Get All Skills",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/skills",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "skills"],
              "query": [
                { "key": "category", "value": "frontend", "disabled": true }
              ]
            },
            "description": "Get all skills. Optional filter: category (frontend|backend|tools|soft-skills|other)."
          }
        },
        {
          "name": "Get Skill by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/skills/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "skills", ":id"],
              "variable": [{ "key": "id", "value": "{{skillId}}" }]
            }
          }
        },
        {
          "name": "Create Skill",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "React", "type": "text" },
                { "key": "category", "value": "frontend", "type": "text", "description": "frontend|backend|tools|soft-skills|other" },
                { "key": "proficiency", "value": "90", "type": "text", "description": "0-100" },
                { "key": "yearsOfExperience", "value": "5", "type": "text" },
                { "key": "description", "value": "Optional skill description", "type": "text" },
                { "key": "relatedSkills", "value": "[\"TypeScript\",\"Next.js\"]", "type": "text", "description": "JSON array" },
                { "key": "order", "value": "1", "type": "text" },
                { "key": "isActive", "value": "true", "type": "text" },
                { "key": "icon", "value": "", "type": "file", "disabled": true, "description": "Optional icon image" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/skills",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "skills"]
            }
          }
        },
        {
          "name": "Update Skill",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "proficiency", "value": "95", "type": "text" },
                { "key": "yearsOfExperience", "value": "6", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/skills/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "skills", ":id"],
              "variable": [{ "key": "id", "value": "{{skillId}}" }]
            }
          }
        },
        {
          "name": "Delete Skill",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/skills/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "skills", ":id"],
              "variable": [{ "key": "id", "value": "{{skillId}}" }]
            }
          }
        }
      ]
    },
    {
      "name": "Experience",
      "description": "Work experience CRUD endpoints. GET routes are public; POST/PUT/DELETE require JWT.",
      "item": [
        {
          "name": "Get All Experience",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/experience",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "experience"]
            }
          }
        },
        {
          "name": "Get Experience by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/experience/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "experience", ":id"],
              "variable": [{ "key": "id", "value": "{{experienceId}}" }]
            }
          }
        },
        {
          "name": "Create Experience",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"company\": \"Acme Corp\",\n  \"position\": \"Senior Developer\",\n  \"location\": \"Remote\",\n  \"startDate\": \"2022-01-01\",\n  \"endDate\": null,\n  \"current\": true,\n  \"description\": \"Role description and responsibilities\",\n  \"achievements\": [\n    \"Led team of 5 developers\",\n    \"Improved performance by 40%\"\n  ],\n  \"technologies\": [\"React\", \"Node.js\", \"AWS\"],\n  \"order\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/experience",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "experience"]
            }
          }
        },
        {
          "name": "Update Experience",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current\": false,\n  \"endDate\": \"2024-12-31\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/experience/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "experience", ":id"],
              "variable": [{ "key": "id", "value": "{{experienceId}}" }]
            }
          }
        },
        {
          "name": "Delete Experience",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/experience/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "experience", ":id"],
              "variable": [{ "key": "id", "value": "{{experienceId}}" }]
            }
          }
        }
      ]
    }
  ]
}
